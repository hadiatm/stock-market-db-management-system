DELIMITER //
CREATE PROCEDURE GetInvestorPortfolio(IN investor_id INT)
BEGIN
    SELECT i.Name, p.TotalValue
    FROM Investor i
    JOIN Portfolio p ON i.InvestorID = p.InvestorID
    WHERE i.InvestorID = investor_id;
END //
DELIMITER ;
CALL GetInvestorPortfolio(1);

