-- Module 2: Broker Management
-- View Broker Details
select * from Broker;

-- Update Broker Commission
update Broker
set CommissionRate=0.25
where BrokerID=1;

-- Calculate Broker Commission
select b.BrokerName,
sum((t.Quantity*s.Price)*b.CommissionRate/100) as CommissionEarned
from Broker b
join TransactionRecord t on b.BrokerID=t.BrokerID
join Stock s on t.StockID=s.StockID
group by b.BrokerName;


-- Module 3: Stock and Transaction Management
-- Record Stock Buy or Sell Transactions
insert into TransactionRecord
(TransactionID,InvestorID,BrokerID,StockID,Quantity,TradeType,TradeDate)
values
