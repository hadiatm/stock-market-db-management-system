create database StockMarketDB;
use StockMarketDB;

create table Broker(
    BrokerID int primary key auto_increment ,
    BrokerName varchar(150) not null,
    LicenseNo varchar(50) unique not null,
    CommissionRate decimal(5,2) not null);

create table Investor(
    InvestorID int primary key auto_increment,
    Name varchar(100) not null,
    Email varchar(100) unique,
    Phone varchar(20),
    BrokerID int,
    foreign key (BrokerID) references Broker(BrokerID)
);

create table Stock(
    StockID int primary key auto_increment,
    Symbol varchar(20) unique not null,
    CompanyName varchar(100) not null,
    Price decimal(10,2) not null);
    
create table TransactionRecord(
    TransactionID int primary key auto_increment,
    InvestorID int,
    BrokerID int,
    StockID int,
    Quantity int not null,
    TradeType varchar(10) not null,
    TradeDate date not null,
    foreign key (InvestorID) references Investor(InvestorID),
    foreign key (BrokerID) references Broker(BrokerID),
    foreign key (StockID) references Stock(StockID)
);

create table Portfolio(
    PortfolioID int primary key auto_increment,
    InvestorID int unique,
    TotalValue decimal(12,2),
    foreign key (InvestorID) references Investor(InvestorID)
);

