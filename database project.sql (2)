-- Maintain Stock Information
update Stock
set Price=35.50
where StockID=2;

-- Filter Transactions
select *
from TransactionRecord
where TradeType='Buy';

-- Module 4: Performance Analytics
-- Profit or Loss Calculation
select s.Symbol,
sum(
case
when t.TradeType='Buy' then -(t.Quantity*s.Price)
when t.TradeType='Sell' then (t.Quantity*s.Price)
end
) as ProfitOrLoss
from Stock s
join TransactionRecord t on s.StockID=t.StockID
group by s.Symbol;

-- Monthly Transaction Summary
select month(TradeDate) as TradeMonth,
count(*) as TotalTransactions
from TransactionRecord
group by month(TradeDate);

-- F. Functional Requirements

-- Track Portfolio Holdings
select i.Name,p.TotalValue
from Investor i
join Portfolio p on i.InvestorID=p.InvestorID;

-- Search and Filter Data
select *
from Stock
where Price>50;

-- G. Queries

-- Total Investment Per Investor
select i.Name,
sum(t.Quantity*s.Price) as TotalInvestment
from Investor i
join TransactionRecord t on i.InvestorID=t.InvestorID
join Stock s on t.StockID=s.StockID
where t.TradeType='Buy'
group by i.Name;

-- Profit or Loss Per Stock
select s.Symbol,
sum(
case
when t.TradeType='Buy' then -(t.Quantity*s.Price)
when t.TradeType='Sell' then (t.Quantity*s.Price)
end
) as ProfitOrLoss
from Stock s
join TransactionRecord t on s.StockID=t.StockID
group by s.Symbol;

-- Commission Earned By Each Broker
select b.BrokerName,
sum((t.Quantity*s.Price)*b.CommissionRate/100) as CommissionEarned
from Broker b
join TransactionRecord t on b.BrokerID=t.BrokerID
join Stock s on t.StockID=s.StockID
group by b.BrokerName;

-- Most Active Broker Using Count
select b.BrokerName,
count(*) as TotalTransactions
from Broker b
join TransactionRecord t on b.BrokerID=t.BrokerID
group by b.BrokerName
order by TotalTransactions desc;

-- Portfolio Value Using Join
select i.Name,p.TotalValue
from Investor i
join Portfolio p on i.InvestorID=p.InvestorID;

-- Monthly Transaction Summary
select month(TradeDate) as TradeMonth,
count(*) as TotalTransactions
from TransactionRecord
group by month(TradeDate);

